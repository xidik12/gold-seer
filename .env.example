# Griffin Gold Configuration

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBAPP_URL=https://your-domain.com

# Gold Data APIs
GOLDAPI_KEY=                    # GoldAPI.io — real-time XAUUSD spot price
FRED_API_KEY=                   # FRED — real yields, TIPS, CPI, M2, DXY (free from https://fred.stlouisfed.org/docs/api/api_key.html)
ALPHA_VANTAGE_API_KEY=          # Alpha Vantage — FX_INTRADAY XAUUSD fallback
OANDA_API_KEY=                  # Oanda — forex/gold data (optional)

# News & Sentiment
CRYPTOPANIC_API_KEY=your_cryptopanic_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=griffin-gold/1.0

# Database
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./griffin_gold.db
# Production (PostgreSQL — Railway auto-sets this via PG plugin):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Backups (enabled by default, runs every 6h)
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_HOURS=6
# BACKUP_DIR=/data/backups
# BACKUP_RETENTION_DAYS=7
# BACKUP_SQLITE_SNAPSHOT=true

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ML
MODEL_DIR=app/models/weights
PREDICTION_INTERVAL_MINUTES=60

# Broker Integration
BROKER_ENABLED=false
METAAPI_TOKEN=                  # MetaApi SDK token for MT4/MT5 bridge
DEFAULT_BROKER=demo             # demo | metaapi
MAX_DAILY_LOSS_PCT=5.0
MAX_OPEN_POSITIONS=3
DEFAULT_LOT_SIZE=0.01

# White-Label (leave empty for default Griffin Gold branding)
WHITELABEL_BROKER_CODE=

# Redis
REDIS_URL=redis://localhost:6379/0
