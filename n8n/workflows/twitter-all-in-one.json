    {
      "parameters": {
        "jsCode": "const news = $('Fetch News').first().json;\nconst summary = $input.first().json;\nconst topArticle = news.articles[0];\nconst chartUrl = 'https://griffin-gold-production.up.railway.app/api/charts/prediction-card.png?timeframe=1h&size=twitter';\nconst prompt = `Write a quote-tweet style commentary adding AI perspective to this Bitcoin news headline:\\nHeadline: ${topArticle.title}\\nSource: ${topArticle.source || 'Unknown'}\\nOur prediction context: ${JSON.stringify(summary)}\\n\\nRules:\\n- Max 270 characters\\n- Add our AI prediction angle to the news\\n- Include #Gold #XAUUSD hashtags\\n- End with CTA to try @GriffinGoldBot\\n- Be data-driven and educational\\n- Never give financial advice\\n- Vary format and wording\\n\\nReturn ONLY the tweet text, nothing else.`;\nconst systemPrompt = 'You are Griffin Gold AI, the social media voice of Griffin Gold — an AI-powered Gold prediction platform (@GriffinGoldBot on Telegram). Your personality: data-driven, educational, transparent about accuracy (including misses), never gives financial advice, uses clear language. Always include a CTA to try the bot. Vary your format and wording — never post the same structure twice. Use emojis sparingly but effectively.';\nreturn [{ json: { prompt, systemPrompt, chartUrl } }];"
      },
