      "position": [220, 1500]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nif (!data.data || data.data.length === 0) {\n  return [];\n}\n// Filter to questions (contains '?' or common question words)\nconst questions = data.data.filter(t => \n  t.text.includes('?') || \n  /\\b(what|how|when|why|will|should|can|is|does|predict)\\b/i.test(t.text)\n);\n// Limit to 3 replies per run\nconst limited = questions.slice(0, 3);\nreturn limited.map(tweet => ({\n  json: {\n    tweetId: tweet.id,\n    tweetText: tweet.text,\n    authorId: tweet.author_id,\n    conversationId: tweet.conversation_id\n  }\n}));"
