        "jsCode": "const response = $input.first().json;\nconst text = response.content[0].text.trim();\nconst chartUrl = $('Build Weekly Prompt').first().json.chartUrl;\nconst tweets = JSON.parse(text);\nconst items = tweets.map((tweet, index) => ({\n  json: {\n    tweetText: tweet,\n    index,\n    isFirst: index === 0,\n    chartUrl: index === 0 ? chartUrl : null\n  }\n}));\nreturn items;"
