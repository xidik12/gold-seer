        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "query", "value": "@GriffinGoldBot -is:retweet" },
            { "name": "max_results", "value": "10" },
            { "name": "tweet.fields", "value": "author_id,conversation_id,created_at,text" }
          ]
        },
        "options": {}
