      "id": "trigger-anomaly",
      "name": "Anomaly Check :05",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://griffin-gold-production.up.railway.app/api/marketing/performance-card?days=1",
        "options": {}
      },
      "id": "fetch-anomaly-perf",
      "name": "Fetch Performance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        -60
      ]
    },
    {
      "parameters": {
        "url": "https://griffin-gold-production.up.railway.app/api/health",
        "options": {}
      },
      "id": "fetch-anomaly-health",
      "name": "Fetch Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        60
      ]
    },
    {
      "parameters": {
        "jsCode": "const perf = $('Fetch Performance').first().json;\nconst health = $('Fetch Health').first().json;\nconst alerts = [];\nlet hasAnomaly = false;\nconst predMade = perf.predictions_made ?? perf.predictionsMade ?? 0;\nconst predCorrect = perf.predictions_correct ?? perf.predictionsCorrect ?? 0;\nconst accuracy = predMade > 0 ? (predCorrect / predMade) * 100 : null;\nif (accuracy !== null && accuracy < 50) {\n  alerts.push(`\\u26a0\\ufe0f Prediction accuracy critically low: ${accuracy.toFixed(1)}% (${predCorrect}/${predMade}) in last 24h`);\n  hasAnomaly = true;\n}\nconst healthStatus = (health.status ?? '').toLowerCase();\nif (healthStatus !== 'ok' && healthStatus !== 'healthy') {\n  alerts.push(`\\ud83d\\udea8 Health check failed: status is \"${health.status ?? 'unreachable'}\"`);\n  hasAnomaly = true;\n}\nconst apiErrors = health.api_errors ?? health.apiErrors ?? health.errorCount ?? null;\nconst apiRequests = health.api_requests ?? health.apiRequests ?? health.requestCount ?? null;\nif (apiErrors !== null && apiRequests !== null && apiRequests > 0) {\n  const errorRate = (apiErrors / apiRequests) * 100;\n  if (errorRate > 10) {\n    alerts.push(`\\ud83d\\udd25 High API error rate: ${errorRate.toFixed(1)}% (${apiErrors}/${apiRequests} requests)`);\n    hasAnomaly = true;\n  }\n}\nconst responseTime = health.response_time_ms ?? health.responseTimeMs ?? health.avgResponseTime ?? null;\nif (responseTime !== null && responseTime > 5000) {\n  alerts.push(`\\ud83d\\udc22 Slow API response time: ${responseTime}ms (threshold: 5000ms)`);\n  hasAnomaly = true;\n}\nreturn [{ json: { hasAnomaly, alerts, alertCount: alerts.length, timestamp: new Date().toISOString() } }];"
      },
      "id": "check-anomalies",
      "name": "Check Anomalies",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-has-anomaly",
              "leftValue": "={{ $json.hasAnomaly }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-anomaly",
      "name": "Has Anomaly?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst alertLines = data.alerts.join('\\n');\nconst tgText = `<b>\\ud83d\\udea8 Griffin Gold Anomaly Alert</b>\\n\\n${alertLines}\\n\\n<i>${data.timestamp}</i>`;\nconst discordText = `**\\ud83d\\udea8 Griffin Gold Anomaly Alert**\\n\\n${alertLines}\\n\\n_${data.timestamp}_`;\nreturn [{ json: { tgText, discordText } }];"
      },
      "id": "build-anomaly-msg",
      "name": "Build Alert Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
