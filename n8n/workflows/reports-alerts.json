    {
      "parameters": {
        "jsCode": "const users = $('Fetch User Metrics').first().json;\nconst revenue = $('Fetch Revenue Metrics').first().json;\nconst perf = $('Fetch Daily Perf').first().json;\nconst health = $('Fetch Daily Health').first().json;\nconst now = new Date().toISOString().split('T')[0];\nconst text = `<b>\\ud83d\\udcca Griffin Gold Daily Report \\u2014 ${now}</b>\\n\\n` +\n  `<b>Users</b>\\n` +\n  `\\u2022 Total: ${users.total_users ?? 'N/A'}\\n` +\n  `\\u2022 New today: ${users.new_today ?? 'N/A'}\\n` +\n  `\\u2022 Active (24h): ${users.active_24h ?? 'N/A'}\\n` +\n  `\\u2022 Premium: ${users.premium_users ?? 'N/A'}\\n\\n` +\n  `<b>Revenue</b>\\n` +\n  `\\u2022 Today: $${revenue.today ?? '0'}\\n` +\n  `\\u2022 MTD: $${revenue.mtd ?? '0'}\\n` +\n  `\\u2022 MRR: $${revenue.mrr ?? '0'}\\n\\n` +\n  `<b>Predictions</b>\\n` +\n  `\\u2022 Made: ${perf.predictions_made ?? perf.predictionsMade ?? 'N/A'}\\n` +\n  `\\u2022 Accuracy: ${perf.accuracy_pct ?? perf.accuracyPct ?? 'N/A'}%\\n\\n` +\n  `<b>Health</b>\\n` +\n  `\\u2022 Status: ${health.status ?? 'N/A'}\\n` +\n  `\\u2022 Uptime: ${health.uptime ?? 'N/A'}`;\nreturn [{ json: { text } }];"
      },
