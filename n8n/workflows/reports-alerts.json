        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.CLAUDE_MODEL || 'claude-sonnet-4-6-20250929' }}\",\n  \"max_tokens\": 2000,\n  \"system\": \"You are a business analyst for Griffin Gold, an AI Gold prediction platform.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Provide a comprehensive weekly business analysis for Griffin Gold. Include key insights, trends, and actionable recommendations. Analyze user growth, revenue, prediction accuracy, and system health. Be concise but thorough. Max 1500 characters.\\n\\nUser Metrics:\\n{{ JSON.stringify($json.users) }}\\n\\nRevenue Metrics:\\n{{ JSON.stringify($json.revenue) }}\\n\\nPerformance (7 days):\\n{{ JSON.stringify($json.perf) }}\\n\\nHealth:\\n{{ JSON.stringify($json.health) }}\\n\\nAccuracy History (7 days):\\n{{ JSON.stringify($json.accuracy) }}\"\n    }\n  ]\n}",
