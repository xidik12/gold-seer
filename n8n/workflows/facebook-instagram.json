    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: $env.CLAUDE_MODEL || 'claude-sonnet-4-6-20250929', max_tokens: 600, messages: [{ role: 'user', content: 'Based on this Gold prediction data:\\n' + JSON.stringify($json) + '\\n\\nChart: https://griffin-gold-production.up.railway.app/api/charts/prediction-card.png?timeframe=24h&size=instagram\\n\\nWrite an Instagram caption for this prediction post. Include hashtags. Max 500 chars. Use #Gold #XAUUSD #CryptoPrediction #AITrading #GriffinGold.' }] }) }}",
        "options": {}
      },
      "id": "ig-daily-claude",
      "name": "IG Claude Caption",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 400]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst text = response.content[0].text;\nconst chartUrl = 'https://griffin-gold-production.up.railway.app/api/charts/prediction-card.png?timeframe=24h&size=instagram';\nreturn [{ json: { caption: text, chartUrl } }];"
      },
      "id": "ig-daily-extract",
      "name": "IG Extract Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $env.META_IG_USER_ID }}/media",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ image_url: $json.chartUrl, caption: $json.caption, access_token: $env.META_PAGE_ACCESS_TOKEN }) }}",
        "options": {}
      },
      "id": "ig-daily-create-media",
      "name": "IG Create Media",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $env.META_IG_USER_ID }}/media_publish",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ creation_id: $json.id, access_token: $env.META_PAGE_ACCESS_TOKEN }) }}",
        "options": {}
      },
      "id": "ig-daily-publish",
      "name": "IG Publish",
